{
  "entities": {
    "User": {
      "title": "User",
      "description": "Private user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "description": "User's email address" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the app" }
      },
      "required": ["uid", "email", "role"]
    },
    "Profile": {
      "title": "Profile",
      "description": "Public user profile for the leaderboard",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "totalPoints": { "type": "number", "description": "Total points earned by the user" },
        "favoriteTeam": { "type": "string", "description": "User's favorite team" },
        "avatarUrl": { "type": "string", "description": "User's chosen avatar URL" },
        "previousRank": { "type": "number", "description": "User's rank before the last update" },
        "rankHistory": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "timestamp": { "type": "string", "format": "date-time" },
              "rank": { "type": "number" }
            }
          },
          "description": "History of user's rank over time"
        },
        "topScorer": { "type": "string", "description": "User's prediction for the tournament top scorer" }
      },
      "required": ["uid", "displayName", "totalPoints"]
    },
    "Match": {
      "title": "Match",
      "description": "A football match in the tournament",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the match" },
        "homeTeam": { "type": "string", "description": "Name of the home team" },
        "awayTeam": { "type": "string", "description": "Name of the away team" },
        "date": { "type": "string", "format": "date-time", "description": "Date and time of the match" },
        "homeScore": { "type": "number", "description": "Actual home team score (null if not played)" },
        "awayScore": { "type": "number", "description": "Actual away team score (null if not played)" },
        "status": { "type": "string", "enum": ["scheduled", "finished"], "description": "Current status of the match" }
      },
      "required": ["id", "homeTeam", "awayTeam", "date", "status"]
    },
    "Prediction": {
      "title": "Prediction",
      "description": "A user's prediction for a specific match",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the prediction" },
        "userId": { "type": "string", "description": "ID of the user who made the prediction" },
        "matchId": { "type": "string", "description": "ID of the match being predicted" },
        "homeScore": { "type": "number", "description": "Predicted home team score" },
        "awayScore": { "type": "number", "description": "Predicted away team score" },
        "pointsEarned": { "type": "number", "description": "Points earned for this prediction (calculated after match)" }
      },
      "required": ["id", "userId", "matchId", "homeScore", "awayScore"]
    },
    "BonusQuestion": {
      "title": "BonusQuestion",
      "description": "A bonus question for extra points",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "question": { "type": "string", "description": "The question text" },
        "points": { "type": "number", "description": "Points awarded for correct answer" },
        "options": { "type": "array", "items": { "type": "string" }, "description": "Possible answers" },
        "correctAnswer": { "type": "string", "description": "The correct answer" },
        "deadline": { "type": "string", "format": "date-time", "description": "Deadline for answering" },
        "status": { "type": "string", "enum": ["open", "closed", "finished"], "description": "Current status" }
      },
      "required": ["id", "question", "points", "deadline", "status"]
    },
    "BonusAnswer": {
      "title": "BonusAnswer",
      "description": "A user's answer to a bonus question",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "userId": { "type": "string", "description": "ID of the user" },
        "questionId": { "type": "string", "description": "ID of the bonus question" },
        "answer": { "type": "string", "description": "User's answer" },
        "pointsEarned": { "type": "number", "description": "Points earned" }
      },
      "required": ["id", "userId", "questionId", "answer"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in the chatbox",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "userId": { "type": "string", "description": "ID of the user" },
        "userName": { "type": "string", "description": "Name of the user" },
        "text": { "type": "string", "description": "Message text" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" },
        "avatarUrl": { "type": "string", "description": "User's avatar URL" }
      },
      "required": ["id", "userId", "userName", "text", "timestamp"]
    },
    "Poll": {
      "title": "Poll",
      "description": "A quick poll for users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "question", "options", "status", "createdAt"]
    },
    "PollVote": {
      "title": "PollVote",
      "description": "A user's vote in a poll",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "pollId": { "type": "string" },
        "optionIndex": { "type": "number" }
      },
      "required": ["userId", "pollId", "optionIndex"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "type", "read", "createdAt"]
    },
    "TournamentSettings": {
      "title": "TournamentSettings",
      "description": "Global tournament settings and results",
      "type": "object",
      "properties": {
        "officialTopScorer": { "type": "string", "description": "The official top scorer of the tournament" },
        "topScorerPoints": { "type": "number", "description": "Points awarded for correctly predicting the top scorer" },
        "topScorerAwarded": { "type": "boolean", "description": "Whether top scorer points have already been awarded" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Collection of private user information" },
    "/profiles/{userId}": { "schema": "Profile", "description": "Collection of public user profiles for the leaderboard" },
    "/matches/{matchId}": { "schema": "Match", "description": "Collection of tournament matches" },
    "/predictions/{predictionId}": { "schema": "Prediction", "description": "Collection of user predictions" },
    "/bonusQuestions/{questionId}": { "schema": "BonusQuestion", "description": "Collection of bonus questions" },
    "/bonusAnswers/{answerId}": { "schema": "BonusAnswer", "description": "Collection of user bonus answers" },
    "/messages/{messageId}": { "schema": "Message", "description": "Collection of chat messages" },
    "/polls/{pollId}": { "schema": "Poll", "description": "Collection of quick polls" },
    "/pollVotes/{id}": { "schema": "PollVote", "description": "Collection of poll votes" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "Collection of user notifications" },
    "/tournamentSettings/{id}": { "schema": "TournamentSettings", "description": "Collection for global tournament settings" }
  }
}
